# URL pubblico dell'app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sorgente dati parcheggi: "osm" (default, reale, nessuna chiave) | "supabase" | "demo"
NEXT_PUBLIC_PARKING_SOURCE=osm

# Modalità demo (dati sintetici, offline). Lasciare false per usare dati reali.
NEXT_PUBLIC_DEMO_MODE=false

# Supabase (opzionale): abilita autenticazione (magic link) e sync cloud di
# piani, preferiti e profilo. Non inserire MAI la service role key nel client.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Mapbox (opzionale): geocoding, routing e mappa di qualità superiore.
# Senza token si usano Nominatim + MapLibre + tile OpenStreetMap (nessuna chiave).
NEXT_PUBLIC_MAPBOX_TOKEN=
